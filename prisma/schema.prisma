// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// prisma/schema.prisma

enum Role {
  USER
  ADMIN
  CUSTOMER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      Role     @default(USER) // Everyone starts as a regular USER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SoapBatch {
  id                    String   @id @default(cuid())
  sheetId               String   @unique
  name                  String   // This MUST be provided
  recipe                String?  @default("N/A") // Added default
  onHandLabeled         Int?     @default(0)
  onHandUnlabeled       Int?     @default(0)
  madeDate              DateTime?
  readyDate             DateTime?
  waterOz               Float?   @default(0) // Added default
  additionalIngredients String?  @default("None")
  fragranceOil          String?  @default("None")
  fragranceAmountOz     Float?   @default(0)
  colorDesign           String?  @default("Plain")
  oilTemp               Float?   @default(0)
  lyeTemp               Float?   @default(0)
  notes                 String?  @default("")
  updatedAt DateTime @default(now()) @updatedAt
}